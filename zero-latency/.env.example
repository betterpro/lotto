# Copy to .env and fill in. All values are optional for a local demo run.

# Database. Defaults to a local SQLite file if unset. For production use Postgres:
#   DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///./bookings.db

# Stripe. Leave STRIPE_SECRET_KEY blank to run in demo mode (no real charges).
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Currency (ISO 4217). Default CAD.
CURRENCY=CAD

# Public origin for Stripe redirect URLs, e.g. https://book.zerolatencyvr-richmond.com
# If blank it's derived from the incoming request.
PUBLIC_BASE_URL=
